generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupStatus {
  ACTIVE
  ALMOST_FULL
  FULL
  ARCHIVED
}

enum GroupRequestStatus {
  NEW
  REVIEWED
  CREATED
  IGNORED
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryChildren")
  groups      WhatsAppGroup[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppGroup {
  id             String      @id @default(cuid())
  name           String
  inviteLink     String
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory    String?
  location       String?
  description    String
  tags           String[]
  status         GroupStatus @default(ACTIVE)
  isFeatured     Boolean     @default(false)
  clicks         Int         @default(0)
  lastVerifiedAt DateTime?
  groupRequests  GroupRequest[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([location])
  @@index([isFeatured])
}

model SearchLog {
  id              String   @id @default(cuid())
  query           String
  matchedCategory String?
  matchedLocation String?
  resultsFound    Boolean
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([resultsFound])
  @@index([matchedCategory])
  @@index([matchedLocation])
}

model GroupRequest {
  id              String             @id @default(cuid())
  name            String?
  whatsappNumber  String?
  query           String
  category        String?
  location        String?
  notes           String?
  status          GroupRequestStatus @default(NEW)
  createdGroupId  String?
  createdGroup    WhatsAppGroup?     @relation(fields: [createdGroupId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([category])
  @@index([location])
  @@index([createdGroupId])
}
